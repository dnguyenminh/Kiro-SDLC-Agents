{
  "name": "code-intel-extension",
  "displayName": "Code Intelligence",
  "description": "Lightweight proxy extension for Code Intelligence Backend MCP Server",
  "version": "1.0.0",
  "publisher": "code-intel",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["workspaceContains:.code-intel"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "codeIntel.reconnect", "title": "Code Intelligence: Reconnect Backend" },
      { "command": "codeIntel.openDashboard", "title": "Code Intelligence: Open Dashboard" },
      { "command": "codeIntel.openKBGraph", "title": "Code Intelligence: Open KB Graph" },
      { "command": "codeIntel.openAnalytics", "title": "Code Intelligence: Open Analytics" },
      { "command": "codeIntel.showStatus", "title": "Code Intelligence: Show Status" }
    ],
    "configuration": {
      "title": "Code Intelligence",
      "properties": {
        "codeIntel.backend.port": { "type": "number", "default": 48721, "minimum": 1024, "maximum": 65535, "description": "Backend server port" },
        "codeIntel.backend.host": { "type": "string", "default": "127.0.0.1", "description": "Backend server host" },
        "codeIntel.backend.path": { "type": "string", "default": "", "description": "Path to Backend executable" },
        "codeIntel.backend.autoStart": { "type": "boolean", "default": true, "description": "Auto-start Backend on activation" },
        "codeIntel.backend.healthCheckInterval": { "type": "number", "default": 5000, "description": "Health check interval (ms)" },
        "codeIntel.backend.startupTimeout": { "type": "number", "default": 30000, "description": "Backend startup timeout (ms)" },
        "codeIntel.backend.compatRange": { "type": "string", "default": "^1.0.0", "description": "Compatible Backend version range" }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "package": "vsce package",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": { "zod": "^3.23.0" }
}
