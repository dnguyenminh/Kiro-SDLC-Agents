<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Sequence: Expand Cluster on Zoom In&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="200" y="10" width="350" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="dev_life" value="Developer" style="shape=umlLifeline;perimeter=lifelinePerimeter;size=16;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="60" y="60" width="100" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="camera_life" value="OrbitControls" style="shape=umlLifeline;perimeter=lifelinePerimeter;size=16;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="220" y="60" width="100" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="lod_life" value="LODManager" style="shape=umlLifeline;perimeter=lifelinePerimeter;size=16;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="380" y="60" width="100" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="budget_life" value="BudgetManager" style="shape=umlLifeline;perimeter=lifelinePerimeter;size=16;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="540" y="60" width="100" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="anim_life" value="AnimController" style="shape=umlLifeline;perimeter=lifelinePerimeter;size=16;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="700" y="60" width="100" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="m1" value="1. zoom()" style="html=1;endArrow=classic;endSize=6;rounded=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="110" y="130" as="sourcePoint"/>
        <mxPoint x="270" y="130" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="2. cameraPosition" style="html=1;endArrow=classic;endSize=6;rounded=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="270" y="170" as="sourcePoint"/>
        <mxPoint x="430" y="170" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m3" value="3. checkDistance()" style="html=1;endArrow=classic;endSize=6;rounded=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="430" y="210" as="sourcePoint"/>
        <mxPoint x="430" y="240" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="480" y="210"/>
          <mxPoint x="480" y="240"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m4" value="4. canExpand(cluster)?" style="html=1;endArrow=classic;endSize=6;rounded=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="430" y="270" as="sourcePoint"/>
        <mxPoint x="590" y="270" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="5. true (budget OK)" style="html=1;endArrow=classic;endSize=6;rounded=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="590" y="310" as="sourcePoint"/>
        <mxPoint x="430" y="310" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m6" value="6. animateExpand(cluster)" style="html=1;endArrow=classic;endSize=6;rounded=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="430" y="350" as="sourcePoint"/>
        <mxPoint x="750" y="350" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m7" value="7. hide superNode, show children" style="html=1;endArrow=classic;endSize=6;rounded=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="750" y="400" as="sourcePoint"/>
        <mxPoint x="430" y="400" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m8" value="8. animation complete" style="html=1;endArrow=classic;endSize=6;rounded=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="750" y="450" as="sourcePoint"/>
        <mxPoint x="430" y="450" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m9" value="9. state = EXPANDED" style="html=1;endArrow=classic;endSize=6;rounded=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="430" y="490" as="sourcePoint"/>
        <mxPoint x="430" y="520" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="480" y="490"/>
          <mxPoint x="480" y="520"/>
        </Array>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
