        <mxPoint x="780" y="130" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="e3" value="3. User record + passwordHash" style="html=1;endSize=6;dashed=1;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="780" y="160" as="sourcePoint"/>
        <mxPoint x="360" y="160" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="e4" value="4. Generate JWT token" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
