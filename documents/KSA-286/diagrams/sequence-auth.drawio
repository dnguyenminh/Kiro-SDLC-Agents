      <mxGeometry x="720" y="40" width="120" height="480" as="geometry"/>
    </mxCell>
    <mxCell id="e1" value="1. POST /api/auth/login&#10;{username, password}" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="140" y="100" as="sourcePoint"/>
        <mxPoint x="360" y="100" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="e2" value="2. Verify credentials" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
