<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="browser" value="&lt;b&gt;Browser (SPA)&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=16;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="80" y="40" width="120" height="480" as="geometry"/>
    </mxCell>
    <mxCell id="backend" value="&lt;b&gt;Backend Server&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=16;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
