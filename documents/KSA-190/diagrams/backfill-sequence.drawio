<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="Sequence Diagram — Batch Backfill (mem_graph auto_link)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="150" y="10" width="450" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="dev" value="Developer" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e1f5fe;strokeColor=#0288d1;size=40;" vertex="1" parent="1">
      <mxGeometry x="60" y="50" width="80" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="mcp" value="MCP Server" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e1f5fe;strokeColor=#0288d1;size=40;" vertex="1" parent="1">
      <mxGeometry x="200" y="50" width="80" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="linker" value="AutoLinker" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#fff9c4;strokeColor=#f9a825;size=40;" vertex="1" parent="1">
      <mxGeometry x="370" y="50" width="80" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="repo" value="KnowledgeRepo" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e8f5e9;strokeColor=#388e3c;size=40;" vertex="1" parent="1">
      <mxGeometry x="530" y="50" width="100" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="graph" value="GraphRepo" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e8f5e9;strokeColor=#388e3c;size=40;" vertex="1" parent="1">
      <mxGeometry x="680" y="50" width="80" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="m1" value="mem_graph action=auto_link" style="html=1;verticalAlign=bottom;endArrow=block;rounded=1;" edge="1" parent="1" source="dev" target="mcp">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="m2" value="backfill()" style="html=1;verticalAlign=bottom;endArrow=block;rounded=1;" edge="1" parent="1" source="mcp" target="linker">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="m3" value="findOrphanEntries(limit=50)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=1;" edge="1" parent="1" source="linker" target="repo">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="m4" value="orphanIds[]" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=1;" edge="1" parent="1" source="repo" target="linker">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="loop" value="loop [for each orphanId]" style="shape=umlFrame;whiteSpace=wrap;html=1;width=180;height=20;fillColor=none;strokeColor=#666666;" vertex="1" parent="1">
      <mxGeometry x="340" y="250" width="400" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="m5" value="link(orphanId)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=1;" edge="1" parent="1" source="linker" target="linker">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="450" y="290"/>
          <mxPoint x="450" y="340"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m6" value="addEdge() x N" style="html=1;verticalAlign=bottom;endArrow=block;rounded=1;" edge="1" parent="1" source="linker" target="graph">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="m7" value="BackfillResult&#xa;(processed, edges)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=1;" edge="1" parent="1" source="linker" target="mcp">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="m8" value="Backfill: processed N,&#xa;created M edges" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=1;" edge="1" parent="1" source="mcp" target="dev">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
