<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="Sequence Diagram — Single Entry Ingest with Auto-Linking" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="150" y="10" width="500" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="dev" value="Developer" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e1f5fe;strokeColor=#0288d1;size=40;" vertex="1" parent="1">
      <mxGeometry x="60" y="50" width="80" height="600" as="geometry"/>
    </mxCell>
    <mxCell id="mcp" value="MCP Server" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e1f5fe;strokeColor=#0288d1;size=40;" vertex="1" parent="1">
      <mxGeometry x="200" y="50" width="80" height="600" as="geometry"/>
    </mxCell>
    <mxCell id="pipe" value="IngestPipeline" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#fff9c4;strokeColor=#f9a825;size=40;" vertex="1" parent="1">
      <mxGeometry x="340" y="50" width="100" height="600" as="geometry"/>
    </mxCell>
    <mxCell id="linker" value="AutoLinker" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#fff9c4;strokeColor=#f9a825;size=40;" vertex="1" parent="1">
      <mxGeometry x="500" y="50" width="80" height="600" as="geometry"/>
    </mxCell>
    <mxCell id="graph" value="GraphRepo" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e8f5e9;strokeColor=#388e3c;size=40;" vertex="1" parent="1">
      <mxGeometry x="640" y="50" width="80" height="600" as="geometry"/>
    </mxCell>
    <mxCell id="m1" value="mem_ingest(content, tags)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=1;" edge="1" parent="1" source="dev" target="mcp">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="100" y="120" as="sourcePoint"/>
        <mxPoint x="240" y="120" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="ingestEntry()" style="html=1;verticalAlign=bottom;endArrow=block;rounded=1;" edge="1" parent="1" source="mcp" target="pipe">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="240" y="150" as="sourcePoint"/>
        <mxPoint x="390" y="150" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m3" value="insert + embed + extractMap" style="html=1;verticalAlign=bottom;endArrow=block;rounded=1;dashed=1;" edge="1" parent="1" source="pipe" target="pipe">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="390" y="180" as="sourcePoint"/>
        <mxPoint x="430" y="180" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="430" y="200"/>
          <mxPoint x="430" y="230"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m4" value="tryAutoLink(entryId)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=1;" edge="1" parent="1" source="pipe" target="linker">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="390" y="260" as="sourcePoint"/>
        <mxPoint x="540" y="260" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="link(entryId)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=1;" edge="1" parent="1" source="linker" target="linker">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="540" y="290" as="sourcePoint"/>
        <mxPoint x="580" y="290" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="580" y="300"/>
          <mxPoint x="580" y="400"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5l" value="semantic + entity&#xa;+ tag + fts" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="585" y="330" width="90" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="m6" value="addEdge() x N" style="html=1;verticalAlign=bottom;endArrow=block;rounded=1;" edge="1" parent="1" source="linker" target="graph">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="540" y="420" as="sourcePoint"/>
        <mxPoint x="680" y="420" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m7" value="AutoLinkResult" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=1;" edge="1" parent="1" source="linker" target="pipe">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="540" y="470" as="sourcePoint"/>
        <mxPoint x="390" y="470" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m8" value="IngestEntryResult&#xa;+ linkCount" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=1;" edge="1" parent="1" source="pipe" target="mcp">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="390" y="510" as="sourcePoint"/>
        <mxPoint x="240" y="510" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m9" value="response with&#xa;auto-link count" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=1;" edge="1" parent="1" source="mcp" target="dev">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="240" y="550" as="sourcePoint"/>
        <mxPoint x="100" y="550" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
