<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="&lt;b&gt;KSA-37: MCP Handshake Sequence&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="150" y="10" width="350" height="30" as="geometry"/>
    </mxCell>
    <!-- Lifelines -->
    <mxCell id="ll1" value="Kiro Agent" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#fff3e0;strokeColor=#f57c00;" vertex="1" parent="1">
      <mxGeometry x="100" y="50" width="100" height="400" as="geometry"/>
    </mxCell>
    <mxCell id="ll2" value="MCP Server&#xa;(stdio)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#e1f5fe;strokeColor=#0288d1;" vertex="1" parent="1">
      <mxGeometry x="350" y="50" width="100" height="400" as="geometry"/>
    </mxCell>
    <mxCell id="ll3" value="Ktor HTTP&#xa;Server" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#e8f5e9;strokeColor=#388e3c;" vertex="1" parent="1">
      <mxGeometry x="550" y="50" width="100" height="400" as="geometry"/>
    </mxCell>
    <!-- Messages -->
    <mxCell id="m1" value="initialize(protocolVersion, capabilities)" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="150" y="120" as="sourcePoint"/>
        <mxPoint x="400" y="120" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="{protocolVersion, capabilities, serverInfo}" style="html=1;endSize=6;dashed=1;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="400" y="160" as="sourcePoint"/>
        <mxPoint x="150" y="160" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m3" value="tools/list" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="150" y="210" as="sourcePoint"/>
        <mxPoint x="400" y="210" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m4" value="{tools: []}" style="html=1;endSize=6;dashed=1;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="400" y="250" as="sourcePoint"/>
        <mxPoint x="150" y="250" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="ping" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="150" y="300" as="sourcePoint"/>
        <mxPoint x="400" y="300" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m6" value="{}" style="html=1;endSize=6;dashed=1;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="400" y="340" as="sourcePoint"/>
        <mxPoint x="150" y="340" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <!-- Note -->
    <mxCell id="note1" value="All communication via&#xa;stdin/stdout (JSON-RPC 2.0)&#xa;One JSON per line" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#fff9e6;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="200" y="380" width="180" height="60" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
