    <mxCell id="actor3" value="Developer&#xa;(CLI)" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;" vertex="1" parent="1">
      <mxGeometry x="60" y="340" width="40" height="60" as="geometry"/>
    </mxCell>
    <!-- Edges: Kiro Agent -->
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=none;" edge="1" source="actor1" target="uc1" parent="1">
