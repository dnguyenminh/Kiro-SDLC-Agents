<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="&lt;b&gt;KSA-37: Server Lifecycle State Diagram&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="200" y="10" width="350" height="30" as="geometry"/>
    </mxCell>
    <!-- States -->
    <mxCell id="start" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="370" y="60" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="s1" value="STARTING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;" vertex="1" parent="1">
      <mxGeometry x="305" y="140" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="s2" value="RUNNING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="305" y="270" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="s3" value="SHUTTING_DOWN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="1">
      <mxGeometry x="305" y="400" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="end" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;shape=doubleCircle;" vertex="1" parent="1">
      <mxGeometry x="370" y="520" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="s_err" value="ERROR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="1">
      <mxGeometry x="560" y="140" width="140" height="60" as="geometry"/>
    </mxCell>
    <!-- Transitions -->
    <mxCell id="e1" value="CLI parsed OK" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="start" target="s1" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e2" value="Both transports ready" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="s1" target="s2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e3" value="stdin EOF / SIGTERM" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="s2" target="s3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e4" value="Cleanup done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="s3" target="end" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e5" value="Invalid args / port conflict" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="s1" target="s_err" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e6" value="Exit(1)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="s_err" target="end" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Self-loop on RUNNING -->
    <mxCell id="e7" value="Process requests" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="s2" target="s2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
