    <mxCell id="hook_loader_class" value="&lt;b&gt;HookLoader&lt;/b&gt;&#10;───────────&#10;- cachedHooks: HookDefinition[]&#10;- outputChannel: OutputChannel&#10;───────────&#10;+ loadHooks(root, force): Promise&lt;HookDefinition[]&gt;&#10;+ clearHookCache(): void&#10;+ filterHooksByType(hooks, type): HookDefinition[]&#10;+ filterPreToolUseHooks(hooks, category): HookDefinition[]&#10;+ filterFileHooks(hooks, type, path): HookDefinition[]&#10;- validateHook(parsed, file): ValidationResult&#10;- matchGlob(pattern, path): boolean" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
