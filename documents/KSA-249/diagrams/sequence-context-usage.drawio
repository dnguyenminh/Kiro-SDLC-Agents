<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Sequence: Context Usage Update Flow&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="200" y="10" width="360" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="dev_life" value="Developer" style="shape=umlLifeline;perimeter=lifelinePerimeter;size=16;fillColor=#e1f5fe;strokeColor=#0288d1;html=1;" vertex="1" parent="1">
      <mxGeometry x="80" y="50" width="80" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="webview_life" value="Chat Webview" style="shape=umlLifeline;perimeter=lifelinePerimeter;size=16;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;" vertex="1" parent="1">
      <mxGeometry x="240" y="50" width="100" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="provider_life" value="ChatPanelProvider" style="shape=umlLifeline;perimeter=lifelinePerimeter;size=16;fillColor=#d5e8d4;strokeColor=#82b366;html=1;" vertex="1" parent="1">
      <mxGeometry x="420" y="50" width="120" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="engine_life" value="LangGraph Engine" style="shape=umlLifeline;perimeter=lifelinePerimeter;size=16;fillColor=#e8f5e9;strokeColor=#388e3c;html=1;" vertex="1" parent="1">
      <mxGeometry x="620" y="50" width="120" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="m1" value="sendMessage(text)" style="html=1;endSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="120" y="120" as="sourcePoint"/>
        <mxPoint x="290" y="120" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="chat:userMessage" style="html=1;endSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="290" y="150" as="sourcePoint"/>
        <mxPoint x="480" y="150" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m3" value="invoke(prompt)" style="html=1;endSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="480" y="180" as="sourcePoint"/>
        <mxPoint x="680" y="180" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m4" value="stream response + tool calls" style="html=1;endSize=6;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="680" y="240" as="sourcePoint"/>
        <mxPoint x="480" y="240" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="calculateContextUsage()" style="html=1;endSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="480" y="280" as="sourcePoint"/>
        <mxPoint x="480" y="310" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="530" y="280"/>
          <mxPoint x="530" y="310"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m6" value="chat:contextUsage(payload)" style="html=1;endSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="480" y="340" as="sourcePoint"/>
        <mxPoint x="290" y="340" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m7" value="render bars + animate" style="html=1;endSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="290" y="370" as="sourcePoint"/>
        <mxPoint x="290" y="400" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="340" y="370"/>
          <mxPoint x="340" y="400"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m8" value="checkThreshold()" style="html=1;endSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="290" y="420" as="sourcePoint"/>
        <mxPoint x="290" y="450" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="340" y="420"/>
          <mxPoint x="340" y="450"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m9" value="[if threshold crossed] auto-expand panel" style="html=1;endSize=6;dashed=1;fontSize=9;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="290" y="470" as="sourcePoint"/>
        <mxPoint x="120" y="470" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="note1" value="Token breakdown:&#10;- conversation: messages&#10;- mcpTools: tool results&#10;- steering: loaded rules" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
      <mxGeometry x="560" y="280" width="180" height="70" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
