    <mxCell id="hooks_detail" value="&lt;b&gt;Hooks System (hook-loader.ts + hook-events.ts + hook-executor.ts)&lt;/b&gt;" style="rounded=1;dashed=1;dashPattern=5 5;fillColor=none;strokeColor=#f57c00;verticalAlign=top;fontSize=12;arcSize=8;html=1;" vertex="1" parent="1">
      <mxGeometry x="880" y="520" width="860" height="400" as="geometry" />
    </mxCell>

    <mxCell id="hk_dir" value="&lt;b&gt;.kiro/hooks/&lt;/b&gt;&#10;&#10;log-prompt.json&#10;drawio-check.json&#10;lint-on-save.json&#10;..." style="rounded=1;fillColor=#f5f5f5;strokeColor=#666666;html=1;whiteSpace=wrap;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
      <mxGeometry x="900" y="560" width="160" height="120" as="geometry" />
    </mxCell>

    <mxCell id="hk_schema" value="&lt;b&gt;Hook Schema:&lt;/b&gt;&#10;&#10;{&#10;  name, version,&#10;  when: {&#10;    type: preToolUse |&#10;      postToolUse | agentStop |&#10;      promptSubmit |&#10;      fileEdited | fileCreated |&#10;      preTaskExecution |&#10;      postTaskExecution |&#10;      userTriggered&#10;    toolTypes: [write, .*sql.*]&#10;    patterns: [*.ts, *.drawio]&#10;  },&#10;  then: {&#10;    type: askAgent | runCommand&#10;    prompt: ...&#10;    command: ...&#10;  }&#10;}" style="rounded=1;fillColor=#fff3e0;strokeColor=#f57c00;html=1;whiteSpace=wrap;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
      <mxGeometry x="1100" y="545" width="240" height="330" as="geometry" />
    </mxCell>

    <mxCell id="hk_events" value="&lt;b&gt;HookEventsManager&lt;/b&gt;&#10;&#10;Event Dispatch:&#10;promptSubmit = log to KB&#10;preToolUse = validate/deny&#10;postToolUse = process result&#10;agentStop = ingest output&#10;fileEdited = lint / index&#10;fileCreated = ingest / layout&#10;userTriggered = VS Code cmd&#10;&#10;Features:&#10;Circular detection (max 3)&#10;Denial pattern matching&#10;Placeholder substitution&#10;  {{toolName}} {{toolArgs}}&#10;  {{toolResult}} {{nodeName}}&#10;Timeout + kill (SIGTERM)" style="rounded=1;fillColor=#fff3e0;strokeColor=#f57c00;html=1;whiteSpace=wrap;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
      <mxGeometry x="1380" y="545" width="220" height="330" as="geometry" />
    </mxCell>

    <mxCell id="hk_commands" value="&lt;b&gt;HookCommands&lt;/b&gt;&#10;&#10;userTriggered hooks =&#10;VS Code commands:&#10;kiro-sdlc.hook.{name}" style="rounded=1;fillColor=#e1f5fe;strokeColor=#0288d1;html=1;whiteSpace=wrap;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="900" y="720" width="170" height="90" as="geometry" />
    </mxCell>

    <mxCell id="e_hk1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="hk_dir" target="hk_schema" parent="1">
