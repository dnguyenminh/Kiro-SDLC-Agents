    <!-- Edges: Tool Proxy → HTTP Server -->
    <mxCell id="e1" edge="1" parent="1" source="tool_proxy" target="http_server" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#6c8ebf;strokeWidth=2;endArrow=classic;endSize=6;">
