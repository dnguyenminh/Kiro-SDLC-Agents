    <!-- Edges: Connection Manager → HTTP Server -->
    <mxCell id="e2" edge="1" parent="1" source="conn_mgr" target="http_server" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#6c8ebf;strokeWidth=2;endArrow=classic;endSize=6;dashed=1;">
