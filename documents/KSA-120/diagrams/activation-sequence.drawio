      <mxGeometry x="740" y="60" width="100" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="m1" value="activate(context)" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="130" y="130" as="sourcePoint"/>
        <mxPoint x="290" y="130" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="registerCommands(13)" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
