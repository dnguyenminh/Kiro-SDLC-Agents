    <mxCell id="impact_check" value="Impact&#10;Analysis?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="670" width="140" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="combine" value="&lt;b&gt;Combine Results&lt;/b&gt;&#10;Call Graph + Dep Graph&#10;+ Test Detection&#10;+ Severity Classification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="540" y="670" width="200" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="end" value="Return response&#10;to caller" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="310" y="810" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="start" target="resolve" parent="1">
