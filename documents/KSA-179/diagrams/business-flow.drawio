    </mxCell>
    <mxCell id="empty" value="Return empty result&#10;+ suggestions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="540" y="310" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="service" value="&lt;b&gt;Graph Service&lt;/b&gt;&#10;BFS/DFS traversal on&#10;relationships table" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="290" y="430" width="200" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="format" value="&lt;b&gt;Format Results&lt;/b&gt;&#10;Add metadata: depth,&#10;truncation, timing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="290" y="550" width="200" height="70" as="geometry"/>
