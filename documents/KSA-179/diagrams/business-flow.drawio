<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Graph Engine — Business Flow&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="250" y="10" width="300" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="start" value="Developer/AI Agent&#10;invokes graph tool" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="310" y="60" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="resolve" value="&lt;b&gt;Symbol Resolver&lt;/b&gt;&#10;Resolve input to DB records&#10;(exact → qualified → file:sym)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="290" y="180" width="200" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="check" value="Symbol&#10;found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
