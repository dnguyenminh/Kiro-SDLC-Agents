    </mxCell>
    <mxCell id="dep_graph_svc" value="&lt;b&gt;DependencyGraphService&lt;/b&gt;&#10;─────────────&#10;+ query(file, direction, depth)&#10;- _bfs_traversal(root, dir, depth)&#10;- _get_outgoing_deps(file)&#10;- _get_incoming_deps(file)&#10;- _merge_results(out, in)" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="360" y="200" width="260" height="120" as="geometry"/>
