    <mxCell id="call_graph_svc" value="&lt;b&gt;CallGraphService&lt;/b&gt;&#10;─────────────&#10;+ find_callers(symbol, depth, limit)&#10;+ find_callees(symbol, depth, limit)&#10;- _query_callers(name, kind, limit)&#10;- _match_filter(path, filter)" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=10;" vertex="1" parent="1">
