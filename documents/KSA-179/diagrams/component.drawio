    <mxCell id="impact_svc" value="&lt;b&gt;ImpactAnalysisService&lt;/b&gt;&#10;─────────────&#10;+ analyze_impact(symbol, action, depth)&#10;- _classify_severity(depth, action)&#10;- _find_implementors(resolved)&#10;- _generate_recommendations(impacts)&#10;- _deduplicate(impacts)&#10;- _filter_by_severity(impacts, threshold)" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=10;" vertex="1" parent="1">
