<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;KB Contradiction Resolution — Business Flow&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="200" y="10" width="400" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="start" value="New Entry&#10;Ingested" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="340" y="60" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="detect_signal" value="Detect Supersession&#10;Signal in Content" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="160" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="has_signal" value="Signal&#10;Found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="330" y="270" width="140" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="find_conflict" value="Find Conflicting Entries&#10;(Entity Overlap or FTS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="400" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="compute_conf" value="Compute&#10;Confidence Score" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="510" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="check_conf" value="Confidence&#10;&gt;= 0.6?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="330" y="620" width="140" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="mark_superseded" value="Mark Old Entries&#10;SUPERSEDED&#10;(Strategy 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="180" y="750" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="create_edge" value="Create SUPERSEDES&#10;Graph Edge&#10;(Strategy 3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="460" y="750" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="log_audit" value="Log Resolution&#10;to Audit Table" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="870" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="no_action" value="No Action&#10;(Store Entry)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="580" y="290" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="end" value="Done" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="340" y="980" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="search_title" value="&lt;b&gt;Search Flow (Filtering)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="820" y="60" width="180" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="search_start" value="Hybrid Search&#10;Returns Top-K" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="790" y="110" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="filter_status" value="Filter by&#10;validity_status&#10;(Strategy 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="780" y="220" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="filter_graph" value="Filter by&#10;SUPERSEDES Edges&#10;(Strategy 3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="780" y="330" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="llm_check" value="LLM&#10;Enabled?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="800" y="440" width="120" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="llm_consolidate" value="LLM Consolidation&#10;(Strategy 2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="780" y="570" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="return_results" value="Return Filtered&#10;Results to Agent" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="790" y="700" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="skip_llm" value="Skip LLM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="1000" y="460" width="100" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="start" target="detect_signal" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="detect_signal" target="has_signal" parent="1">
      <mxGeometry relative="1" as="geometry"/>
