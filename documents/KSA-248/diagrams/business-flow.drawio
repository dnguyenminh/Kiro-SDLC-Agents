    <mxCell id="e3" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="has_signal" target="find_conflict" parent="1">
      <mxGeometry relative="1" as="geometry"/>
