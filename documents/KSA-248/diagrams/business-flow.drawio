    <mxCell id="e7" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="check_conf" target="mark_superseded" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="260" y="660"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e8" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="check_conf" target="create_edge" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
