    </mxCell>
    <mxCell id="mcp_bridge" value="MCP Bridge&#10;Route to Backend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="300" y="410" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="security_check" value="Security Check&#10;SSRF + Rate Limit" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="295" y="530" width="170" height="90" as="geometry"/>
    </mxCell>
    <mxCell id="blocked" value="Return Error&#10;(Blocked)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="540" y="545" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="execute" value="Execute Request&#10;(HTTP/Browser/API)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="300" y="670" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="truncate" value="Truncate/Sanitize&#10;(max 100KB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="300" y="790" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="respond" value="Return to Agent&#10;via MCP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="300" y="910" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="end" value="User Gets&#10;Answer" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="1030" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="tools_list" value="fetch_url | web_search&#10;git_browse | download_file&#10;api_call | read_webpage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="540" y="290" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="start" target="agent_parse" parent="1">
      <mxGeometry relative="1" as="geometry"/>
