      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e7" value="Pass" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="security_check" target="execute" parent="1">
      <mxGeometry relative="1" as="geometry"/>
