<mxGraphModel adaptiveColors="auto"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="system" value="LangGraph Self-Correction System" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="220" y="40" width="520" height="560" as="geometry"/></mxCell><mxCell id="uc1" value="Auto-Retry on Error&#xa;(max 2 attempts)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="system"><mxGeometry x="40" y="40" width="200" height="80" as="geometry"/></mxCell><mxCell id="uc2" value="Verify Agent Output&#xa;(quality check)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="system"><mxGeometry x="280" y="40" width="200" height="80" as="geometry"/></mxCell><mxCell id="uc3" value="Retry with Feedback&#xa;(after verify fail)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="system"><mxGeometry x="40" y="160" width="200" height="80" as="geometry"/></mxCell><mxCell id="uc4" value="Switch Strategy&#xa;(alternate prompt)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="system"><mxGeometry x="280" y="160" width="200" height="80" as="geometry"/></mxCell><mxCell id="uc5" value="Pause Pipeline&#xa;(human intervention)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="system"><mxGeometry x="160" y="280" width="200" height="80" as="geometry"/></mxCell><mxCell id="uc6" value="Emit Stream Events&#xa;(retry/verify/switch)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="system"><mxGeometry x="40" y="400" width="200" height="80" as="geometry"/></mxCell><mxCell id="uc7" value="Resume Pipeline&#xa;(with human feedback)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#