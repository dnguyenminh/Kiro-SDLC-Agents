    </mxCell>
    <mxCell id="refresh_timer" value="Token Expiry&#10;Approaching?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="590" y="520" width="140" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="refresh_token" value="Call SSO OIDC&#10;CreateToken (refresh)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="570" y="650" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="update_cache" value="Update In-Memory Token&#10;+ Write Back to Cache" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="570" y="760" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="start" target="scan_creds" parent="1">
