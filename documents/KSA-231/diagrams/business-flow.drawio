    <mxCell id="e14" value="Timer fires" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;dashed=1;fontSize=10;" edge="1" source="schedule_refresh" target="refresh_timer" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e15" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="refresh_timer" target="refresh_token" parent="1">
      <mxGeometry relative="1" as="geometry"/>
