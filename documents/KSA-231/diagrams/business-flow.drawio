<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Business Flow — Kiro API Client Integration (KSA-231)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="180" y="10" width="460" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="start" value="Extension&#10;Activates" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="360" y="60" width="100" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="scan_creds" value="TokenManager Scans&#10;~/.aws/sso/cache/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="170" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="creds_found" value="Valid Token&#10;Found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="340" y="280" width="140" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="no_creds" value="Show Notification:&#10;Please login via&#10;Kiro IDE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="570" y="290" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="store_token" value="Store Token&#10;in Memory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="410" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="schedule_refresh" value="Schedule Refresh&#10;Timer (5min before expiry)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="520" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="fetch_models" value="ModelRegistry Fetches&#10;Available Models from API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="630" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="populate_settings" value="Populate Settings&#10;Panel Dropdown" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="740" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="user_prompt" value="User Sends&#10;Prompt via Chat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="850" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="adapter" value="AnthropicAdapter&#10;Formats Request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="960" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="api_call" value="KiroClient Sends to&#10;Kiro API (Bearer token)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="1070" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="stream_sse" value="StreamHandler&#10;Processes SSE Chunks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="1180" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="render" value="Chat Panel&#10;Renders Tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="1290" width="180" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="end" value="Response&#10;Complete" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
