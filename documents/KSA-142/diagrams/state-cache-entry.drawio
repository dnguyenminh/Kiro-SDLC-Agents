<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="State Diagram: Cache Entry Lifecycle" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="150" y="10" width="350" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="start" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;html=1;" vertex="1" parent="1">
      <mxGeometry x="305" y="60" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="created" value="Created" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="250" y="140" width="140" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="active" value="Active" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="250" y="260" width="140" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="expired" value="Expired" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="40" y="420" width="140" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="evicted" value="Evicted (LRU)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="250" y="420" width="140" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="invalidated" value="Invalidated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="460" y="420" width="140" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="end_ring" value="" style="ellipse;fillColor=none;strokeColor=#000000;html=1;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="300" y="560" width="40" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="end" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;html=1;" vertex="1" parent="1">
      <mxGeometry x="305" y="565" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="e1" value="cache.set()" style="html=1;rounded=1;endArrow=classic;endSize=6;fontSize=9;" edge="1" source="start" target="created" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e2" value="TTL valid" style="html=1;rounded=1;endArrow=classic;endSize=6;fontSize=9;" edge="1" source="created" target="active" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e3" value="cache.get() hit&#xa;update LRU" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=9;" edge="1" source="active" target="active" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e4" value="TTL exceeded" style="html=1;rounded=1;endArrow=classic;endSize=6;fontSize=9;" edge="1" source="active" target="expired" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="110" y="310"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e5" value="max_size reached" style="html=1;rounded=1;endArrow=classic;endSize=6;fontSize=9;" edge="1" source="active" target="evicted" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e6" value="event invalidation" style="html=1;rounded=1;endArrow=classic;endSize=6;fontSize=9;" edge="1" source="active" target="invalidated" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="530" y="310"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e7" value="removed" style="html=1;rounded=1;endArrow=classic;endSize=6;fontSize=9;" edge="1" source="expired" target="end_ring" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="110" y="530"/>
          <mxPoint x="320" y="530"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e8" value="removed" style="html=1;rounded=1;endArrow=classic;endSize=6;fontSize=9;" edge="1" source="evicted" target="end_ring" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e9" value="removed" style="html=1;rounded=1;endArrow=classic;endSize=6;fontSize=9;" edge="1" source="invalidated" target="end_ring" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="530" y="530"/>
          <mxPoint x="320" y="530"/>
        </Array>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>