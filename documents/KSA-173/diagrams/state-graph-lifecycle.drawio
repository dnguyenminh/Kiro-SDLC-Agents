<mxfile>
  <diagram name="State - Graph Lifecycle" id="state_diagram">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="&lt;b&gt;Graph Engine — State Lifecycle&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="initial" value="" style="ellipse;shape=doubleCircle;fillColor=#000000;strokeColor=#000000;html=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="60" width="30" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="uninitialized" value="&lt;b&gt;UNINITIALIZED&lt;/b&gt;&#10;No graph data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="360" y="130" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="building" value="&lt;b&gt;BUILDING&lt;/b&gt;&#10;Constructing graph&#10;from AST data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="360" y="240" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ready" value="&lt;b&gt;READY&lt;/b&gt;&#10;Graph built&#10;Accepting queries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="360" y="360" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="updating" value="&lt;b&gt;UPDATING&lt;/b&gt;&#10;Incremental update&#10;in progress" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="360" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="stale" value="&lt;b&gt;STALE&lt;/b&gt;&#10;Files changed&#10;Graph outdated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="360" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="error" value="&lt;b&gt;ERROR&lt;/b&gt;&#10;Build failed&#10;Partial graph" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="240" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_init" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="initial" target="uninitialized" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_build" value="build()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="uninitialized" target="building" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_done" value="success" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="building" target="ready" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_fail" value="failure" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="building" target="error" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_change" value="file changed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="ready" target="stale" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_incr" value="incremental&#10;update()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="stale" target="updating" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="180" y="480"/>
              <mxPoint x="700" y="480"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_updated" value="success" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="updating" target="ready" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_rebuild" value="rebuild()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="stale" target="building" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="180" y="270"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_retry" value="retry()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;dashed=1;" edge="1" source="error" target="building" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="280" y="270"/>
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
