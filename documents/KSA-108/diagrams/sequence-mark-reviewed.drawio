<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Sequence — Mark Reviewed (Dashboard)&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="150" y="10" width="400" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="actor" value="KB Admin" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#e1f5fe;strokeColor=#0288d1;" vertex="1" parent="1">
      <mxGeometry x="80" y="50" width="100" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="dashboard" value="dashboard.js" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#fff3e0;strokeColor=#f57c00;" vertex="1" parent="1">
      <mxGeometry x="260" y="50" width="100" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="api" value="Backend API" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#e8f5e9;strokeColor=#388e3c;" vertex="1" parent="1">
      <mxGeometry x="440" y="50" width="100" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="db" value="SQLite" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#f3e5f5;strokeColor=#7b1fa2;" vertex="1" parent="1">
      <mxGeometry x="620" y="50" width="100" height="500" as="geometry"/>
    </mxCell>
    <mxCell id="m1" value="1. Click &quot;Mark Reviewed&quot;" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="130" y="120" as="sourcePoint"/>
        <mxPoint x="310" y="120" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="2. Disable button, show spinner" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="310" y="150" as="sourcePoint"/>
        <mxPoint x="310" y="180" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="360" y="150"/>
          <mxPoint x="360" y="180"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m3" value="3. POST /api/kb/entries/{id}/review" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="310" y="210" as="sourcePoint"/>
        <mxPoint x="490" y="210" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m4" value="4. UPDATE staleness_score=0" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="490" y="250" as="sourcePoint"/>
        <mxPoint x="670" y="250" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="5. OK (rows affected)" style="html=1;endSize=6;startSize=6;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="670" y="290" as="sourcePoint"/>
        <mxPoint x="490" y="290" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m6" value="6. 200 {status:ok, entryId}" style="html=1;endSize=6;startSize=6;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="490" y="330" as="sourcePoint"/>
        <mxPoint x="310" y="330" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m7" value="7. Show success toast" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="310" y="370" as="sourcePoint"/>
        <mxPoint x="310" y="400" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="360" y="370"/>
          <mxPoint x="360" y="400"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m8" value="8. Fade out row (300ms)" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="310" y="430" as="sourcePoint"/>
        <mxPoint x="310" y="460" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="360" y="430"/>
          <mxPoint x="360" y="460"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="m9" value="9. Remove row from DOM" style="html=1;endSize=6;startSize=6;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="310" y="490" as="sourcePoint"/>
        <mxPoint x="130" y="490" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
