<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;State Diagram — Mark Reviewed Button&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="150" y="10" width="350" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="start" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
      <mxGeometry x="60" y="95" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="idle" value="&lt;b&gt;Idle&lt;/b&gt;&#xa;Button: &quot;Mark Reviewed&quot;&#xa;Enabled, clickable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="160" y="70" width="180" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="loading" value="&lt;b&gt;Loading&lt;/b&gt;&#xa;Button: spinner icon&#xa;Disabled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="420" y="70" width="180" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="success_dash" value="&lt;b&gt;Success (Dashboard)&lt;/b&gt;&#xa;Row fading out&#xa;Toast shown" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="420" y="240" width="180" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="success_detail" value="&lt;b&gt;Success (Detail)&lt;/b&gt;&#xa;Badge: &quot;Reviewed ✓&quot;&#xa;Toast shown" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="420" y="380" width="180" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="removed" value="&lt;b&gt;Removed&lt;/b&gt;&#xa;Row gone from DOM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="160" y="240" width="180" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="end" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;strokeWidth=3;" vertex="1" parent="1">
      <mxGeometry x="235" y="390" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="e_start" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" parent="1" source="start" target="idle">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_click" value="User clicks" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" parent="1" source="idle" target="loading">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_ok_dash" value="200 OK&#xa;(dashboard)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" parent="1" source="loading" target="success_dash">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_ok_detail" value="200 OK&#xa;(detail)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" parent="1" source="loading" target="success_detail">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="650" y="110"/>
          <mxPoint x="650" y="420"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e_error" value="Error" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;strokeColor=#c62828;" edge="1" parent="1" source="loading" target="idle">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="510" y="50"/>
          <mxPoint x="250" y="50"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e_fade" value="300ms fade" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" parent="1" source="success_dash" target="removed">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_end1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" parent="1" source="removed" target="end">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_end2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" parent="1" source="success_detail" target="end">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="510" y="480"/>
          <mxPoint x="250" y="480"/>
        </Array>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
