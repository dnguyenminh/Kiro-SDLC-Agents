<mxGraphModel adaptiveColors="auto"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="h_user" value="User" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="100" height="40" as="geometry"/></mxCell><mxCell id="h_webview" value="Webview&#xa;(Chat Panel)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="220" y="20" width="120" height="40" as="geometry"/></mxCell><mxCell id="h_spinner" value="SpinnerController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="420" y="20" width="130" height="40" as="geometry"/></mxCell><mxCell id="h_host" value="Extension Host" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="630" y="20" width="120" height="40" as="geometry"/></mxCell><mxCell id="h_ai" value="AI Backend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="830" y="20" width="100" height="40" as="geometry"/></mxCell><mxCell id="l_user" edge="1" parent="1" style="dashed=1;endArrow=none;html=1;strokeColor=#999999;" source="h_user"><mxGeometry relative="1" as="geometry"><mxPoint x="90" y="520" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l_webview" edge="1" parent="1" style="dashed=1;endArrow=none;html=1;strokeColor=#999999;" source="h_webview"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="520" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l_spinner" edge="1" parent="1" style="dashed=1;endArrow=none;html=1;strokeColor=#999999;" source="h_spinner"><mxGeometry relative="1" as="geometry"><mxPoint x="485" y="520" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l_host" edge="1" parent="1" style="dashed=1;endArrow=none;html=1;strokeColor=#999999;" source="h_host"><mxGeometry relative="1" as="g