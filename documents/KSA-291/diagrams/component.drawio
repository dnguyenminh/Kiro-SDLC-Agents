    <mxCell id="e7" value="calls" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;strokeColor=#388e3c;dashed=1;" edge="1" source="expanded_path" target="centroid_detail" parent="1">
