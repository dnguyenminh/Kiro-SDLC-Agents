<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;KSA-291 — Component: Distance Calculation Flow&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="180" y="10" width="400" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="raf_tick" value="&lt;b&gt;requestAnimationFrame&lt;/b&gt;&#10;Browser 60fps loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="280" y="60" width="200" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="check_dist" value="&lt;b&gt;_checkDistances()&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="280" y="150" width="200" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="decision" value="cluster.state?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="290" y="230" width="180" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="collapsed_path" value="COLLAPSED:&#10;dist(cam, cluster.center)&#10;check &lt; expandThreshold" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="80" y="360" width="200" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="expanded_path" value="EXPANDED:&#10;centroid = _getExpandedCentroid()&#10;dist(cam, centroid)&#10;check &gt; collapseThreshold" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="460" y="350" width="230" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="expand_action" value="expandCluster(id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="470" width="160" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="collapse_action" value="collapseCluster(id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="500" y="470" width="160" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="centroid_detail" value="&lt;b&gt;_getExpandedCentroid(cluster)&lt;/b&gt;&#10;1. childNodes = _getChildNodes(cluster)&#10;2. IF empty: return cluster.center&#10;3. sum x/y/z of all children&#10;4. return avg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
      <mxGeometry x="420" y="560" width="280" height="90" as="geometry"/>
    </mxCell>
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="raf_tick" target="check_dist" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="check_dist" target="decision" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e3" value="COLLAPSED" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="decision" target="collapsed_path" parent="1">
      <mxGeometry relative="1" as="geometry"/>
