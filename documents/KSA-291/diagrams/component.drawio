    <mxCell id="e4" value="EXPANDED" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;strokeColor=#c62828;" edge="1" source="decision" target="expanded_path" parent="1">
