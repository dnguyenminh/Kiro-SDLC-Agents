    <mxCell id="e6" value="dist &gt; threshold" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;strokeColor=#c62828;" edge="1" source="expanded_path" target="collapse_action" parent="1">
      <mxGeometry relative="1" as="geometry"/>
