<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Sequence: mem_ingest with Quality Gate + Structured Map&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="100" y="10" width="500" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="ll_agent" value="Agent" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#e1f5fe;strokeColor=#0288d1;" vertex="1" parent="1">
      <mxGeometry x="60" y="50" width="80" height="550" as="geometry"/>
    </mxCell>
    <mxCell id="ll_disp" value="IngestPipeline" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
      <mxGeometry x="200" y="50" width="100" height="550" as="geometry"/>
    </mxCell>
    <mxCell id="ll_qg" value="QualityGate" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#fce4ec;strokeColor=#c62828;" vertex="1" parent="1">
      <mxGeometry x="360" y="50" width="90" height="550" as="geometry"/>
    </mxCell>
    <mxCell id="ll_repo" value="KnowledgeRepo" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#f3e5f5;strokeColor=#7b1fa2;" vertex="1" parent="1">
      <mxGeometry x="500" y="50" width="100" height="550" as="geometry"/>
    </mxCell>
    <mxCell id="ll_sme" value="MapExtractor" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#fff3e0;strokeColor=#f57c00;" vertex="1" parent="1">
      <mxGeometry x="650" y="50" width="90" height="550" as="geometry"/>
    </mxCell>
    <mxCell id="ll_er" value="EntityRepo" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;size=40;fillColor=#fff3e0;strokeColor=#f57c00;" vertex="1" parent="1">
      <mxGeometry x="790" y="50" width="80" height="550" as="geometry"/>
    </mxCell>
    <mxCell id="m1" value="mem_ingest(content, tags, source)" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="100" y="120" as="sourcePoint"/>
        <mxPoint x="250" y="120" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="validate(content, meta)" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="250" y="150" as="sourcePoint"/>
        <mxPoint x="405" y="150" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m3" value="QualityResult {score, decision}" style="html=1;endSize=6;dashed=1;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="405" y="200" as="sourcePoint"/>
        <mxPoint x="250" y="200" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m3b" value="[reject] → return error" style="text;html=1;fontSize=9;fontColor=#c62828;" vertex="1" parent="1">
      <mxGeometry x="260" y="205" width="140" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="m4" value="create(entry)" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="250" y="240" as="sourcePoint"/>
        <mxPoint x="550" y="240" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="entry with ID" style="html=1;endSize=6;dashed=1;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="550" y="270" as="sourcePoint"/>
        <mxPoint x="250" y="270" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m6" value="extractStructuredMap(content)" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="250" y="300" as="sourcePoint"/>
        <mxPoint x="695" y="300" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m7" value="StructuredMap" style="html=1;endSize=6;dashed=1;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="695" y="330" as="sourcePoint"/>
        <mxPoint x="250" y="330" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m8" value="UPDATE structured_map" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="250" y="360" as="sourcePoint"/>
        <mxPoint x="550" y="360" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m9" value="indexEntities(entry_id, entities)" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="250" y="400" as="sourcePoint"/>
        <mxPoint x="830" y="400" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m10" value="{ entry, quality_score, structured_map }" style="html=1;endSize=6;dashed=1;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="250" y="450" as="sourcePoint"/>
        <mxPoint x="100" y="450" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
