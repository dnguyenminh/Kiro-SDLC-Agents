<mxGraphModel adaptiveColors="auto"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="Sequence: SSO Authentication (OIDC + PKCE) — UC-2" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="150" y="10" width="500" height="30" as="geometry"/></mxCell><mxCell id="h_dev" value="Developer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="50" width="90" height="40" as="geometry"/></mxCell><mxCell id="h_ext" value="Extension" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="170" y="50" width="90" height="40" as="geometry"/></mxCell><mxCell id="h_browser" value="Browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="320" y="50" width="90" height="40" as="geometry"/></mxCell><mxCell id="h_backend" value="Backend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="470" y="50" width="90" height="40" as="geometry"/></mxCell><mxCell id="h_idp" value="IdP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1"><mxGeometry x="620" y="50" width="90" height="40" as="geometry"/></mxCell><mxCell id="l1" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="65" y="90" as="sourcePoint"/><mxPoint x="65" y="700" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l2" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="215" y="90" as="sourcePoint"/><mxPoint x="215" y="700" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l3" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="365" y="90" as="sourcePoint"/><mxPoint x="365" y="700" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l4" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="515" y="90" as="sourcePoint"/><mxPoint x="515" y="700" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l5" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="665" y="90" as="sourcePoint"/><mxPoint x="665" y="700" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m1" value="1. Click Login with SSO" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="65" y="120" as="sourcePoint"/><mxPoint x="215" y="120" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m2" value="2. Generate code_verifier + code_challenge (PKCE)" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="215" y="150" as="sourcePoint"/><mxPoint x="215" y="170" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m3" value="3. POST /api/auth/sso/authorize {code_challenge}" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="215" y="180" as="sourcePoint"/><mxPoint x="515" y="180" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m4" value="4. Fetch .well-known/openid-configuration" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="515" y="210" as="sourcePoint"/><mxPoint x="665" y="210" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m5" value="5. Return OIDC discovery doc" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="665" y="240" as="sourcePoint"/><mxPoint x="515" y="240" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m6" value="6. Build auth URL + store state" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="515" y="270" as="sourcePoint"/><mxPoint x="515" y="290" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m7" value="7. Return {authorization_url, state}" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="515" y="300" as="sourcePoint"/><mxPoint x="215" y="300" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m8" value="8. Open system browser with authorization_url" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="215" y="330" as="sourcePoint"/><mxPoint x="365" y="330" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m9" value="9. Redirect to IdP login page" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="365" y="360" as="sourcePoint"/><mxPoint x="665" y="360" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m10" value="10. User authenticates with IdP" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="65" y="400" as="sourcePoint"/><mxPoint x="665" y="400" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m11" value="11. Redirect to callback with code + state" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="665" y="440" as="sourcePoint"/><mxPoint x="515" y="440" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m12" value="12. Validate state, exchange code + code_verifier" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="515" y="470" as="sourcePoint"/><mxPoint x="665" y="470" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m13" value="13. Return id_token + access_token" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="665" y="500" as="sourcePoint"/><mxPoint x="515" y="500" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m14" value="14. Validate token, extract claims, auto-provision user" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="515" y="530" as="sourcePoint"/><mxPoint x="515" y="550" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m15" value="15. Issue own JWT + refresh_token" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="515" y="560" as="sourcePoint"/><mxPoint x="515" y="580" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m16" value="16. Return {access_token, refresh_token}" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="515" y="600" as="sourcePoint"/><mxPoint x="215" y="600" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m17" value="17. Store in SecretStorage, close Login, update status" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="215" y="640" as="sourcePoint"/><mxPoint x="65" y="640" as="targetPoint"/></mxGeometry></mxCell></root></mxGraphModel>
