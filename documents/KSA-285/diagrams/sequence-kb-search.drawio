<mxGraphModel adaptiveColors="auto"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="Sequence: Unified KB Search Across 3 Tiers (UC-11)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="120" y="10" width="500" height="30" as="geometry"/></mxCell><mxCell id="h_agent" value="AI Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="50" width="90" height="40" as="geometry"/></mxCell><mxCell id="h_ext" value="Extension&#xa;Proxy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="170" y="50" width="90" height="40" as="geometry"/></mxCell><mxCell id="h_backend" value="Backend&#xa;KB Module" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="320" y="50" width="90" height="40" as="geometry"/></mxCell><mxCell id="h_onnx" value="ONNX&#xa;Embeddings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="470" y="50" width="90" height="40" as="geometry"/></mxCell><mxCell id="h_db" value="SQLite" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1"><mxGeometry x="620" y="50" width="90" height="40" as="geometry"/></mxCell><mxCell id="l1" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="65" y="90" as="sourcePoint"/><mxPoint x="65" y="620" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l2" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="215" y="90" as="sourcePoint"/><mxPoint x="215" y="620" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l3" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="365" y="90" as="sourcePoint"/><mxPoint x="365" y="620" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l4" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="515" y="90" as="sourcePoint"/><mxPoint x="515" y="620" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l5" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="665" y="90" as="sourcePoint"/><mxPoint x="665" y="620" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m1" value="1. mem_search(query)" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="65" y="120" as="sourcePoint"/><mxPoint x="215" y="120" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m2" value="2. POST /mcp/tools/call {mem_search} + Bearer token" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="215" y="150" as="sourcePoint"/><mxPoint x="365" y="150" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m3" value="3. Extract userId + projects[] from JWT" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="365" y="180" as="sourcePoint"/><mxPoint x="365" y="200" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m4" value="4. Compute query embedding" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="365" y="210" as="sourcePoint"/><mxPoint x="515" y="210" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m5" value="5. Return 384-dim vector" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="515" y="240" as="sourcePoint"/><mxPoint x="365" y="240" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m6" value="6. Query Tier 1: WHERE owner_id=userId" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="365" y="270" as="sourcePoint"/><mxPoint x="665" y="270" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m7" value="7. Return User KB results + similarity scores" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="665" y="300" as="sourcePoint"/><mxPoint x="365" y="300" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m8" value="8. Query Tier 2: WHERE project_id IN projects[]" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="365" y="330" as="sourcePoint"/><mxPoint x="665" y="330" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m9" value="9. Return Project KB results" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="665" y="360" as="sourcePoint"/><mxPoint x="365" y="360" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m10" value="10. Query Tier 3: all entries" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="365" y="390" as="sourcePoint"/><mxPoint x="665" y="390" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m11" value="11. Return Shared KB results" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="665" y="420" as="sourcePoint"/><mxPoint x="365" y="420" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m12" value="12. Apply tier boosts (1.2/1.0/0.9), deduplicate, sort" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="365" y="450" as="sourcePoint"/><mxPoint x="365" y="470" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m13" value="13. Return merged results with tier badges" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="365" y="500" as="sourcePoint"/><mxPoint x="215" y="500" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m14" value="14. Forward results to AI Agent" style="html=1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="215" y="540" as="sourcePoint"/><mxPoint x="65" y="540" as="targetPoint"/></mxGeometry></mxCell></root></mxGraphModel>
