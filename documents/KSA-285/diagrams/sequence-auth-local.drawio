<mxGraphModel adaptiveColors="auto"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="Sequence: Local Authentication (UC-1)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="180" y="10" width="400" height="30" as="geometry"/></mxCell><mxCell id="h_dev" value="Developer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="40" y="50" width="100" height="40" as="geometry"/></mxCell><mxCell id="h_ext" value="Extension" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="200" y="50" width="100" height="40" as="geometry"/></mxCell><mxCell id="h_backend" value="Backend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="380" y="50" width="100" height="40" as="geometry"/></mxCell><mxCell id="h_db" value="SQLite DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1"><mxGeometry x="560" y="50" width="100" height="40" as="geometry"/></mxCell><mxCell id="h_ss" value="SecretStorage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="200" y="570" width="100" height="40" as="geometry"/></mxCell><mxCell id="l_dev" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="90" y="90" as="sourcePoint"/><mxPoint x="90" y="560" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l_ext" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="250" y="90" as="sourcePoint"/><mxPoint x="250" y="560" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l_back" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="430" y="90" as="sourcePoint"/><mxPoint x="430" y="560" as="targetPoint"/></mxGeometry></mxCell><mxCell id="l_db" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="610" y="90" as="sourcePoint"/><mxPoint x="610" y="560" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m1" value="1. Open IDE" style="html=1;fontSize=10;exitX=1;exitY=0;entryX=0;entryY=0;" edge="1" parent="1"><mxGeometry x="0.2" relative="1" as="geometry"><mxPoint x="90" y="120" as="sourcePoint"/><mxPoint x="250" y="120" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m2" value="2. Check SecretStorage for JWT" style="html=1;fontSize=10;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="250" y="150" as="sourcePoint"/><mxPoint x="250" y="170" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m3" value="3. No valid JWT found → Show Login Webview" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="250" y="180" as="sourcePoint"/><mxPoint x="90" y="180" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m4" value="4. Enter username + password, click Login" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="90" y="220" as="sourcePoint"/><mxPoint x="250" y="220" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m5" value="5. POST /api/auth/login {username, password}" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="250" y="260" as="sourcePoint"/><mxPoint x="430" y="260" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m6" value="6. SELECT user WHERE username=?" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="430" y="300" as="sourcePoint"/><mxPoint x="610" y="300" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m7" value="7. Return user record" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="610" y="330" as="sourcePoint"/><mxPoint x="430" y="330" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m8" value="8. bcrypt.compare(password, hash) ✓" style="html=1;fontSize=10;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="430" y="360" as="sourcePoint"/><mxPoint x="430" y="380" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m9" value="9. Generate JWT (HS256, 1h) + refresh token (7d)" style="html=1;fontSize=10;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="430" y="390" as="sourcePoint"/><mxPoint x="430" y="410" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m10" value="10. INSERT session (refresh_token, user_id)" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="430" y="420" as="sourcePoint"/><mxPoint x="610" y="420" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m11" value="11. 200 OK {access_token, refresh_token, expires_in}" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="430" y="460" as="sourcePoint"/><mxPoint x="250" y="460" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m12" value="12. Store tokens in SecretStorage" style="html=1;fontSize=10;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="250" y="490" as="sourcePoint"/><mxPoint x="250" y="510" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m13" value="13. Close Login Webview, update status bar" style="html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="250" y="530" as="sourcePoint"/><mxPoint x="90" y="530" as="targetPoint"/></mxGeometry></mxCell></root></mxGraphModel>
