<mxfile>
  <diagram name="Sequence - Tool Call" id="seq_tool">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="700">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="&lt;b&gt;Sequence: MCP Tool Call Forwarding — KSA-292&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="280" y="10" width="400" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ll_client" value="MCP Client&#10;(Kiro/Copilot)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="60" width="120" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="ll_proxy" value="ToolProxy" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="60" width="120" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="ll_http" value="HttpClient" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="60" width="120" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="ll_backend" value="Remote Backend" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;curved&quot;:0,&quot;rounded&quot;:0};size=40;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="60" width="120" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="m1" value="callTool(name, args)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="140" as="sourcePoint"/>
            <mxPoint x="340" y="140" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m2" value="isLocalTool(name)?" style="html=1;verticalAlign=bottom;endArrow=none;dashed=1;rounded=0;fontSize=10;fontStyle=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="180" as="sourcePoint"/>
            <mxPoint x="340" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m3" value="POST /mcp/tools/call&#10;{name, args} + Bearer token" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="220" as="sourcePoint"/>
            <mxPoint x="540" y="220" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m4" value="fetch(url, {method: POST, body, headers})" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="540" y="260" as="sourcePoint"/>
            <mxPoint x="760" y="260" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m5" value="execute tool" style="html=1;verticalAlign=bottom;endArrow=none;dashed=1;rounded=0;fontSize=10;fontStyle=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="760" y="300" as="sourcePoint"/>
            <mxPoint x="760" y="360" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m6" value="{content: [{type, text}]}" style="html=1;verticalAlign=bottom;endArrow=block;dashed=1;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="760" y="380" as="sourcePoint"/>
            <mxPoint x="540" y="380" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m7" value="ToolResult" style="html=1;verticalAlign=bottom;endArrow=block;dashed=1;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="540" y="420" as="sourcePoint"/>
            <mxPoint x="340" y="420" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m8" value="return result" style="html=1;verticalAlign=bottom;endArrow=block;dashed=1;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="340" y="460" as="sourcePoint"/>
            <mxPoint x="140" y="460" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
