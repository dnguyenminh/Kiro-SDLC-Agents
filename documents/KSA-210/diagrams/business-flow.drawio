<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Business Flow — LangGraph.js Chat Pipeline&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="200" y="10" width="420" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="360" y="60" width="80" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="open_panel" value="Developer Opens&#10;Chat Panel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="150" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="input_cmd" value="User Inputs&#10;Ticket Command" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="250" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="init_graph" value="Initialize&#10;LangGraph StateGraph" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="350" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="route_node" value="Route to&#10;Agent Node" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="330" y="450" width="140" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="exec_mcp" value="Execute MCP&#10;Tool Calls" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="580" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="stream" value="Stream Response&#10;to Chat Panel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="680" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="quality_gate" value="Quality Gate&#10;Checkpoint?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="330" y="790" width="140" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="approval" value="Wait for&#10;Human Approval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="560" y="800" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="approved_check" value="Approved?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="570" y="910" width="140" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="more_nodes" value="More Nodes&#10;in Graph?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="330" y="920" width="140" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="persist" value="Persist State&#10;to Workspace" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="320" y="1050" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="end_done" value="Pipeline&#10;Complete" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="350" y="1150" width="100" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="redo_node" value="Redo Node&#10;with Feedback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="560" y="1040" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="start" target="open_panel" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="open_panel" target="input_cmd" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="input_cmd" target="init_graph" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="init_graph" target="route_node" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="route_node" target="exec_mcp" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="exec_mcp" target="stream" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="stream" target="quality_gate" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e8" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="quality_gate" target="approval" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e9" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="quality_gate" target="more_nodes" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="approval" target="approved_check" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e11" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="approved_check" target="more_nodes" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e12" value="No (Reject)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="approved_check" target="redo_node" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e13" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="more_nodes" target="route_node" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="220" y="960"/>
          <mxPoint x="220" y="490"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e14" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;fontSize=10;" edge="1" source="more_nodes" target="persist" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="persist" target="end_done" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e16" value="Loop back" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;dashed=1;fontSize=10;" edge="1" source="redo_node" target="route_node" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="740" y="1070"/>
          <mxPoint x="740" y="490"/>
        </Array>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>