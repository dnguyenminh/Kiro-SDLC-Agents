{
  "name": "code-intel-backend",
  "version": "1.0.0",
  "description": "Code Intelligence Backend MCP Server — standalone HTTP process",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
