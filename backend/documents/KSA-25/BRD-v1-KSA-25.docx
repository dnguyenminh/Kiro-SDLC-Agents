### Current Schema (Before Migration)

CREATE TABLE modules (
 id INTEGER PRIMARY KEY AUTOINCREMENT,
 name TEXT NOT NULL,
 root\_path TEXT NOT NULL,
 language TEXT,
 file\_count INTEGER DEFAULT 0,
 symbol\_count INTEGER DEFAULT 0,
 last\_indexed TEXT
);

### Target Schema (After Migration)

CREATE TABLE modules (
 id INTEGER PRIMARY KEY AUTOINCREMENT,
 name TEXT NOT NULL,
 root\_path TEXT NOT NULL,
 language TEXT,
 file\_count INTEGER DEFAULT 0,
 symbol\_count INTEGER DEFAULT 0,
 last\_indexed TEXT,
 di\_style TEXT DEFAULT NULL,
 error\_handling TEXT DEFAULT NULL,
 naming\_convention TEXT DEFAULT NULL,
 logging\_framework TEXT DEFAULT NULL,
 testing\_framework TEXT DEFAULT NULL,
 purpose TEXT DEFAULT NULL
);

### Migration SQL

ALTER TABLE modules ADD COLUMN di\_style TEXT DEFAULT NULL;
ALTER TABLE modules ADD COLUMN error\_handling TEXT DEFAULT NULL;
ALTER TABLE modules ADD COLUMN naming\_convention TEXT DEFAULT NULL;
ALTER TABLE modules ADD COLUMN logging\_framework TEXT DEFAULT NULL;
ALTER TABLE modules ADD COLUMN testing\_framework TEXT DEFAULT NULL;
ALTER TABLE modules ADD COLUMN purpose TEXT DEFAULT NULL;