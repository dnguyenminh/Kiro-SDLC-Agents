## 8. Pseudocode for Complex Logic

### 8.1 Call Graph Construction

function buildCallGraph(files: List<File>):
 graph = new DirectedGraph()

 for each file in files:
 symbols = parserProvider.getSymbolTable(file.path)
 ast = parserProvider.getAstRoot(file.path)

 // Add all function/method declarations as nodes
 for each symbol in symbols.functions + symbols.methods:
 graph.addNode(GraphNode(
 id = "${file.path}::${symbol.qualifiedName}",
 type = symbol.type,
 name = symbol.name,
 filePath = file.path
 ))

 // Find all call expressions in AST
 callExpressions = ast.findAll(nodeType = "call\_expression")

 for each call in callExpressions:
 callerSymbol = findEnclosingFunction(call, symbols)
 targetName = extractCallTarget(call)

 // Resolve target
 resolvedTarget = resolveCallTarget(targetName, file, symbols)

 if resolvedTarget != null:
 graph.addEdge(callerSymbol.id, resolvedTarget.id, CALL, confidence=1.0)
 else if isVirtualCall(call):
 implementations = findAllImplementations(targetName, allSymbols)
 for each impl in implementations:
 graph.addEdge(callerSymbol.id, impl.id, CALL, confidence=0.7)
 else:
 graph.addEdge(callerSymbol.id, "UNRESOLVED::${targetName}", UNRESOLVED, confidence=0.0)

 return graph

### 8.2 Tarjan’s SCC for Cycle Detection

function detectCycles(graph: DirectedGraph):
 index = 0
 stack = []
 indices = {}
 lowlinks = {}
 onStack = {}
 sccs = []

 function strongConnect(node):
 indices[node] = index
 lowlinks[node] = index
 index++
 stack.push(node)
 onStack[node] = true

 for each neighbor in graph.getSuccessors(node):
 if neighbor not in indices:
 strongConnect(neighbor)
 lowlinks[node] = min(lowlinks[node], lowlinks[neighbor])
 else if onStack[neighbor]:
 lowlinks[node] = min(lowlinks[node], indices[neighbor])

 if lowlinks[node] == indices[node]:
 scc = []
 do:
 w = stack.pop()
 onStack[w] = false
 scc.add(w)
 while w != node

 if scc.size > 1:
 sccs.add(scc)

 for each node in graph.nodes:
 if node not in indices:
 strongConnect(node)

 return sccs.map { classifyCycle(it) }

### 8.3 Impact Analysis (BFS-based)

function analyzeImpact(target: String, graph: DirectedGraph, maxDepth: Int):
 results = []
 visited = Set()
 queue = Queue()
 queue.enqueue((target, 0))
 visited.add(target)

 while queue is not empty:
 (current, depth) = queue.dequeue()

 if depth > maxDepth:
 break

 // Get all nodes that depend on current (reverse edges)
 dependents = graph.getPredecessors(current)

 for each dep in dependents:
 if dep not in visited:
 visited.add(dep)
 score = calculateImpactScore(dep, depth + 1, graph)
 results.add(ImpactResult(node=dep, distance=depth+1, score=score))
 queue.enqueue((dep, depth + 1))

 return results.sortedByDescending { it.score }

function calculateImpactScore(node: String, distance: Int, graph: DirectedGraph):
 // Score decreases with distance, increases with fan-out
 distanceFactor = 1.0 / distance
 fanOut = graph.getSuccessors(node).size
 fanOutFactor = min(1.0, fanOut / 10.0)
 return distanceFactor \* 0.7 + fanOutFactor \* 0.3

