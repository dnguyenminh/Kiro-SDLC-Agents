 fun getCallees(symbolId: String, depth: Int = 1): List<ImpactResult>
 fun getDependents(filePath: String, depth: Int = 1): List<ImpactResult>
 fun getDependencies(filePath: String, depth: Int = 1): List<ImpactResult>
 fun detectCycles(graphType: GraphType): List<Cycle>
 fun getShortestPath(from: String, to: String): List<String>?
 fun getHotPaths(topN: Int): List<HotPathResult>
