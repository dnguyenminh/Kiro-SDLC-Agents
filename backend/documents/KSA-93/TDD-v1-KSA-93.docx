### 5.2 Key Modules

#### event-bus.js

/\*\*
 \* Lightweight event bus for cross-module communication.
 \* Uses native CustomEvent API.
 \*/
export const EventBus = {
 emit(event, detail) {
 document.dispatchEvent(new CustomEvent(`ux:${event}`, { detail }));
 },
 on(event, handler) {
 document.addEventListener(`ux:${event}`, (e) => handler(e.detail));
 },
 off(event, handler) {
 document.removeEventListener(`ux:${event}`, handler);
 }
};

#### tour.js (Interface)

/\*\*
 \* Onboarding tour engine.
 \* Manages tour state, step navigation, localStorage persistence.
 \*/
export class TourEngine {
 constructor(steps, options = {}) { /\* ... \*/ }

 /\*\* Check if tour should show (first visit) \*/
 shouldShow() { /\* check localStorage \*/ }

 /\*\* Start the tour from step 0 \*/
 start() { /\* ... \*/ }

 /\*\* Advance to next step \*/
 next() { /\* ... \*/ }

 /\*\* Go back one step \*/
 previous() { /\* ... \*/ }

 /\*\* Skip/complete tour, save state \*/
 dismiss() { /\* ... \*/ }

 /\*\* Restart tour (from help menu) \*/
 restart() { /\* ... \*/ }
}

#### tooltips.js (Interface)

/\*\*
 \* Tooltip manager.
 \* Injects ? icons and manages tooltip popups.
 \*/
export class TooltipManager {
 constructor(config) { /\* load tooltip definitions \*/ }

 /\*\* Initialize tooltips for current page \*/
 init(page) { /\* inject ? icons, attach listeners \*/ }

 /\*\* Show tooltip at position near target \*/
 show(tooltipId, targetEl) { /\* ... \*/ }

 /\*\* Hide active tooltip \*/
 hide() { /\* ... \*/ }

 /\*\* Calculate optimal position (avoid viewport overflow) \*/
 \_calculatePosition(targetRect, tooltipRect) { /\* ... \*/ }
}

#### recommendations.js (Interface)

/\*\*
 \* Recommendation cards with Fix Now actions.
 \*/
export class RecommendationPanel {
 constructor(containerEl) { /\* ... \*/ }

 /\*\* Fetch and render recommendations \*/
 async load() { /\* GET /api/kb/recommendations \*/ }

 /\*\* Execute fix action for a recommendation \*/
 async fixNow(recId) { /\* POST to action endpoint \*/ }

 /\*\* Refresh list after action \*/
 async refresh() { /\* re-fetch and re-render \*/ }
}

#### graph-analysis.js (Interface)

/\*\*
 \* Client-side graph analysis algorithms.
 \*/
export class GraphAnalyzer {
 constructor(nodes, edges) { /\* build adjacency list \*/ }

 /\*\* Run all analyses, return insights \*/
 analyze() { /\* ... \*/ }

 /\*\* Find nodes with 0 edges \*/
 findOrphans() { /\* ... \*/ }

 /\*\* Find nodes with >10 edges \*/
 findHubs() { /\* ... \*/ }

 /\*\* Find connected components via BFS \*/
 findComponents() { /\* ... \*/ }

 /\*\* Find nodes not updated in >180 days \*/
