{
  "name": "kiro-sdlc-agents",
  "displayName": "Kiro SDLC Agents",
  "description": "Inject multi-agent SDLC pipeline (BA, SA, QA, DEV, DevOps, UI, Security) with MCP Code Intelligence into any workspace for Kiro IDE",
  "version": "1.26.0",
  "publisher": "dnguyenminh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/kiro-sdlc-agents"
  },
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "kiro",
    "sdlc",
    "agents",
    "multi-agent",
    "BA",
    "QA",
    "DevOps",
    "scrum",
    "mcp"
  ],
  "activationEvents": [
    "onView:kiroSdlcTree",
    "onView:kiroChatPanel",
    "onCommand:kiroSdlc.injectAll",
    "onCommand:kiroSdlc.status",
    "onCommand:kiroSdlc.indexWorkspace",
    "onCommand:kiroSdlc.injectSelective",
    "onCommand:kiroSdlc.update",
    "onCommand:kiroSdlc.downloadModel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kiroSdlc.injectAll",
        "title": "Kiro SDLC: Inject All Agents",
        "icon": "$(cloud-download)"
      },
      {
        "command": "kiroSdlc.injectSelective",
        "title": "Kiro SDLC: Inject (Select Components)"
      },
      {
        "command": "kiroSdlc.update",
        "title": "Kiro SDLC: Update Agents (Keep Customizations)"
      },
      {
        "command": "kiroSdlc.status",
        "title": "Kiro SDLC: Show Status",
        "icon": "$(info)"
      },
      {
        "command": "kiroSdlc.indexWorkspace",
        "title": "Kiro SDLC: Index Workspace (Code + Documents)"
      },
      {
        "command": "kiroSdlc.downloadModel",
        "title": "Kiro SDLC: Download Embedding Model"
      },
      {
        "command": "kiroSdlc.openKbGraph",
        "title": "Kiro SDLC: Open KB Graph"
      },
      {
        "command": "kiroSdlc.openKbDashboard",
        "title": "Kiro SDLC: Open KB Dashboard"
      },
      {
        "command": "kiroSdlc.openKbTags",
        "title": "Kiro SDLC: Open KB Tags"
      },
      {
        "command": "kiroSdlc.openKbQuality",
        "title": "Kiro SDLC: Open KB Quality"
      },
      {
        "command": "kiroSdlc.openKbAnalytics",
        "title": "Kiro SDLC: Open KB Analytics"
      },
      {
        "command": "kiroSdlc.restartMcpServer",
        "title": "Kiro SDLC: Restart MCP Server"
      },
      {
        "command": "kiroSdlc.stopMcpServer",
        "title": "Kiro SDLC: Stop MCP Server"
      },
      {
        "command": "kiroSdlc.openKbBrowser",
        "title": "Kiro SDLC: Open KB in Browser"
      },
      {
        "command": "kiroSdlc.changePort",
        "title": "Kiro SDLC: Change MCP Server Port"
      },
      {
        "command": "kiroSdlc.editConfig",
        "title": "Kiro SDLC: Edit Orchestration Config"
      },
      {
        "command": "kiroSdlc.changeConfig",
        "title": "Kiro SDLC: Change Config File..."
      },
      {
        "command": "kiroSdlc.openKbBrowser",
        "title": "Kiro SDLC: Open KB in Browser"
      },
      {
        "command": "kiroSdlc.symbolSearch",
        "title": "Kiro SDLC: Symbol Search"
      },
      {
        "command": "kiroSdlc.openSecurityPanel",
        "title": "Kiro SDLC: Open Security Panel"
      },
      {
        "command": "kiroSdlc.impactAnalysis",
        "title": "Kiro SDLC: Impact Analysis"
      },
      {
        "command": "kiroSdlc.getAIContext",
        "title": "Kiro SDLC: Get AI Context for Symbol"
      },
      {
        "command": "kiroSdlc.getEditContext",
        "title": "Kiro SDLC: Get Edit Context for Symbol"
      },
      {
        "command": "kiroSdlc.indexSalesforceProject",
        "title": "Kiro SDLC: Index Salesforce Project"
      },
      {
        "command": "kiroSdlc.testLanguageModels",
        "title": "Kiro SDLC: Test Language Models (vscode.lm)"
      },
      {
        "command": "kiroSdlc.setLlmApiKey",
        "title": "Kiro SDLC: Set LLM API Key"
      },
      {
        "command": "kiroSdlc.clearLlmApiKey",
        "title": "Kiro SDLC: Clear LLM API Key"
      },
      {
        "command": "kiroSdlc.openSettings",
        "title": "Kiro SDLC: Settings",
        "icon": "$(gear)"
      },
      {
        "command": "kiroSdlc.openWorkflowGraph",
        "title": "Kiro SDLC: Open Workflow Graph"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kiroSdlc",
          "title": "Kiro SDLC",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "kiroSdlc": [
        {
          "id": "kiroSdlcTree",
          "name": "SDLC Agents"
        },
        {
          "id": "kiroChatPanel",
          "name": "Chat Panel",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Kiro SDLC Agents",
      "properties": {
        "kiroSdlc.enableMcpServer": {
          "type": "boolean",
          "default": true,
          "description": "Enable bundled MCP Code Intelligence server. When disabled, the server will not start automatically."
        },
        "kiroSdlc.mcpServerPort": {
          "type": "number",
          "default": 9181,
          "description": "Port for the bundled MCP server. Change if port conflicts with another service."
        },
        "kiroSdlc.configPath": {
          "type": "string",
          "default": ".code-intel/orchestration.json",
          "description": "Path to orchestration config file (relative to workspace root). Controls MCP server behavior, child servers, and model routing."
        },
        "kiroSdlc.llmProvider": {
          "enum": [
            "anthropic",
            "openai",
            "ollama",
            "onnx"
          ],
          "type": "string",
          "description": "LLM provider for direct agent calls. Anthropic (recommended — use gateway base URL for zero-config). OpenAI requires API key. Ollama runs locally. ONNX runs CPU-only local models.",
          "default": "anthropic"
        },
        "kiroSdlc.kiroModel": {
          "type": "string",
          "default": "",
          "description": "Selected Kiro model ID (auto-populated from API). Leave empty to use default."
        },
        "kiroSdlc.kiroRegion": {
          "type": "string",
          "default": "",
          "description": "AWS region for Kiro API. Leave empty to auto-detect from SSO credentials."
        },
        "kiroSdlc.llmModel": {
          "type": "string",
          "description": "Override the default model for the selected LLM provider. Leave empty to use provider defaults (claude-sonnet-4-20250514, gpt-4o, llama3.1).",
          "default": ""
        },
        "kiroSdlc.anthropicBaseUrl": {
          "type": "string",
          "description": "Custom base URL for Anthropic API. Default points to the standalone Kiro Gateway extension (http://127.0.0.1:8990/anthropic) which uses Kiro IDE credentials. Set your Anthropic key (or the gateway's API key) via Save key. Change to https://api.anthropic.com for direct Anthropic API access.",
          "default": "http://127.0.0.1:8990/anthropic"
        },
        "kiroSdlc.openaiBaseUrl": {
          "type": "string",
          "description": "Custom base URL for OpenAI API. Use for Azure OpenAI, OpenRouter, vLLM, or any OpenAI-compatible endpoint. Leave empty for official API.",
          "default": ""
        },
        "kiroSdlc.ollamaUrl": {
          "type": "string",
          "description": "Base URL for Ollama API when using the ollama provider.",
          "default": "http://localhost:11434"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "kiroSdlc.injectAll",
          "when": "view == kiroSdlcTree",
          "group": "navigation"
        },
        {
          "command": "kiroSdlc.openSettings",
          "when": "view == kiroSdlcTree",
          "group": "navigation"
        },
        {
          "command": "kiroSdlc.status",
          "when": "view == kiroSdlcTree",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run copy-resources && npm run gen-checksums && npm run esbuild-production",
    "compile": "tsc -p ./",
    "esbuild": "node esbuild.js",
    "esbuild-production": "node esbuild.js --production",
    "esbuild-watch": "node esbuild.js --watch",
    "watch": "tsc -watch -p ./",
    "copy-resources": "node scripts/copy-resources.js",
    "gen-checksums": "node scripts/gen-checksums.js",
    "package": "vsce package --no-dependencies",
    "test": "mocha",
    "test:watch": "mocha --watch"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/sinon": "^17.0.3",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.21.0",
    "glob": "^13.0.6",
    "mocha": "^10.7.3",
    "sinon": "^17.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@langchain/core": "^0.3.80",
    "@langchain/langgraph": "^0.2.74",
    "3d-force-graph": "^1.80.0",
    "chart.js": "^4.5.1",
    "filetomarkdown": "^1.0.0",
    "three": "^0.184.0"
  }
}
