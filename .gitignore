# MCP Code Intelligence database (generated at runtime)
.code-intel/

# MCP settings (contains local paths, tokens)
.kiro/settings/mcp.json

# Node.js MCP server build output
mcp-code-intelligence-nodejs/dist/
mcp-code-intelligence-nodejs/node_modules/

# Kotlin MCP server build output
mcp-code-intelligence-kotlin/build/
mcp-code-intelligence-kotlin/bin/
mcp-code-intelligence-kotlin/.gradle/
mcp-code-intelligence-kotlin/.kotlin/

# Python bytecode and test cache
mcp-code-intelligence-python/src/mcp_code_intel/__pycache__/
mcp-code-intelligence-python/src/mcp_code_intel/**/__pycache__/
mcp-code-intelligence-python/src/mcp_code_intel/viewer/
mcp-code-intelligence-python/.pytest_cache/
mcp-code-intelligence-python/tests/__pycache__/

# Extension build output
kiro-sdlc-agents/out/
kiro-sdlc-agents/node_modules/
kiro-sdlc-agents/*.vsix

# Salesforce Intelligence
mcp-salesforce-intelligence/node_modules/
mcp-salesforce-intelligence/dist/

# QA screenshots (generated during testing)
qa-*.png

# Log files
*.log

# Workspace-level code-intel DB
${workspaceFolder}/

kiro-rs/
.vscode/kiro-pipeline-state/
mcp-code-intelligence-nodejs/src/http/kiro-ts/
