{
  "enabled": true,
  "name": "Stream MCP Tool Calls",
  "description": "After MCP tool execution (read, web, spec categories), log tool name and brief result to memory. Excludes write/shell to avoid infinite loops.",
  "version": "4",
  "when": {
    "type": "postToolUse",
    "toolTypes": [
      "read",
      "web",
      "spec"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A tool just executed. Use the mem_ingest MCP tool to log what happened. Parameters: content=<tool_name>: <brief 1-line description, max 100 chars>, type=CONTEXT, source=hook-tool-stream, tags=tool,stream,hook. Extract tool name and summary from the tool result in context. Do NOT add commentary."
  }
}
